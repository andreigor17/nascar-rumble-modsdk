---
import { type Lang } from '../../consts';
import { t } from '../../i18n/ui';
import { GALLERY } from '../../data/gallery';
const { lang } = Astro.props as { lang: Lang };
const tr = t(lang);
const base = import.meta.env.BASE_URL;
---
<section class="section">
  <div class="container">
    <p class="eyebrow">{tr('gallery.title')}</p>
    <h2>{tr('gallery.title')}</h2>
    <p class="lead">{tr('gallery.intro')}</p>
    <div class="grid cols-3">
      {GALLERY.map((s) => (
        <figure class="shot" style="margin:0">
          <img src={`${base}${s.src}`.replace('//', '/')} alt={lang === 'pt' ? s.pt : s.en} loading="lazy" />
          <figcaption class="cap">{lang === 'pt' ? s.pt : s.en}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
