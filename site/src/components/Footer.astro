---
import { SITE, type Lang } from '../consts';
import { t } from '../i18n/ui';
const { lang } = Astro.props as { lang: Lang };
const tr = t(lang);
---
<footer class="site-footer">
  <div class="container">
    <div class="row">
      <span>🏁 NASCAR Rumble ModSDK · <a href={SITE.github} target="_blank" rel="noopener">GitHub</a></span>
      <span>{tr('footer.ai')}</span>
    </div>
    <p style="margin:12px 0 0; font-size:0.82rem;">{tr('footer.disclaimer')}</p>
  </div>
</footer>
