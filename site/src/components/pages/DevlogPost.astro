---
import { href, type Lang } from '../../consts';
import { t } from '../../i18n/ui';
import type { DevlogEntry } from '../../data/devlog';
const { lang, entry } = Astro.props as { lang: Lang; entry: DevlogEntry };
const tr = t(lang);
const c = entry[lang];
const img = entry.image ? `${import.meta.env.BASE_URL}${entry.image}`.replace('//', '/') : null;
---
<section class="section">
  <div class="container">
    <a href={href('/devlog', lang)}>{tr('devlog.back')}</a>
    <p class="eyebrow" style="margin-top:20px">{entry.tag} · #{entry.session} · {entry.date}</p>
    <h1 style="font-size:clamp(1.8rem,4vw,2.6rem); margin:8px 0 16px;">{c.title}</h1>
    <div class="prose">
      <p style="font-size:1.1rem; color:var(--text)">{c.summary}</p>
      {img && (
        <div class="shot" style="margin:24px 0; max-width:420px">
          <img src={img} alt={c.title} loading="lazy" />
        </div>
      )}
      <ul>
        {c.points.map((p) => <li>{p}</li>)}
      </ul>
    </div>
  </div>
</section>
