---
import { href, SITE, STATS, type Lang } from '../../consts';
import { t } from '../../i18n/ui';
import { DEVLOG } from '../../data/devlog';
import { JOURNEY, JOURNEY_STATUS } from '../../data/journey';
const { lang } = Astro.props as { lang: Lang };
const tr = t(lang);
const latest = DEVLOG.slice(0, 3);
const base = import.meta.env.BASE_URL;

const heroSub = lang === 'pt'
  ? 'A jornada aberta para redescobrir o NASCAR Rumble por dentro — e chegar, passo a passo, a algo que os fãs possam explorar, editar e um dia jogar sem emulador.'
  : 'The open journey to rediscover NASCAR Rumble from the inside — and reach, step by step, something fans can explore, edit and one day play without an emulator.';

const gameBody = lang === 'pt'
  ? 'Lançado pela EA em 2000 para PlayStation e Nintendo 64, o NASCAR Rumble pegou a corrida de stock cars e jogou o realismo pela janela: power-ups, atalhos loucos, tempestades e uma garagem de carros absurdos para desbloquear. Um kart racer disfarçado de NASCAR — puro caos divertido de fim de semana.'
  : 'Released by EA in 2000 for PlayStation and Nintendo 64, NASCAR Rumble took stock-car racing and threw realism out the window: power-ups, wild shortcuts, storms and a garage of absurd unlockable cars. A kart racer dressed as NASCAR — pure weekend chaos.';

const funFact = lang === 'pt'
  ? 'Curiosidade: vasculhando o código do jogo já encontramos nomes de carros escondidos como Golf Cart, Jet Car e EA Sports Car.'
  : 'Fun fact: digging through the game code we already found hidden car names like Golf Cart, Jet Car and EA Sports Car.';

const pillars = lang === 'pt'
  ? [
      { i: '🔧', h: 'Engenharia reversa', p: 'Análise do executável no Ghidra: física, IA, renderização, formatos.' },
      { i: '🧰', h: 'SDK de modding', p: 'Ferramentas para extrair e editar texturas, pistas, carros e saves.' },
      { i: '📚', h: 'Base de conhecimento', p: 'Cada descoberta documentada, reproduzível e aberta à comunidade.' },
    ]
  : [
      { i: '🔧', h: 'Reverse engineering', p: 'Executable analysis in Ghidra: physics, AI, rendering, formats.' },
      { i: '🧰', h: 'Modding SDK', p: 'Tools to extract and edit textures, tracks, cars and saves.' },
      { i: '📚', h: 'Knowledge base', p: 'Every discovery documented, reproducible and open to the community.' },
    ];
---
<section class="hero">
  <div class="container">
    <p class="eyebrow">PlayStation 1 · EA · 2000</p>
    <h1>NASCAR Rumble<br />ModSDK</h1>
    <p class="sub">{heroSub}</p>
    <div class="cta">
      <a class="btn primary" href={href('/devlog', lang)}>{tr('hero.cta.devlog')}</a>
      <a class="btn" href={href('/gallery', lang)}>{tr('nav.gallery')}</a>
      <a class="btn" href={SITE.github} target="_blank" rel="noopener">GitHub</a>
    </div>

    <div class="statusbar">
      <span class="dot"></span>
      <strong>{tr('home.status')}:</strong> {JOURNEY_STATUS[lang]}
    </div>

    <div class="stats">
      {STATS.map((s) => (
        <div class="stat">
          <div class="v">{s.value}</div>
          <div class="l">{lang === 'pt' ? s.label_pt : s.label_en}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- O JOGO -->
<section class="section">
  <div class="container">
    <p class="eyebrow">{tr('home.game.eyebrow')}</p>
    <h2>{tr('home.game.title')}</h2>
    <div class="gamegrid">
      <div>
        <p class="lead" style="margin-bottom:16px">{gameBody}</p>
        <p style="color:var(--accent-2); font-weight:600">🏁 {funFact}</p>
        <a class="btn" style="margin-top:18px" href={href('/gallery', lang)}>{tr('home.gallery.cta')}</a>
      </div>
      <figure class="shot" style="margin:0">
        <img src={`${base}/gallery/help1-loading.png`.replace('//', '/')} alt="NASCAR Rumble" loading="lazy" />
      </figure>
    </div>
  </div>
</section>

<!-- QUÃO PERTO -->
<section class="section" style="padding-top:0">
  <div class="container">
    <p class="eyebrow">{tr('home.journey.eyebrow')}</p>
    <h2>{tr('home.journey.title')}</h2>
    <ol class="journey">
      {JOURNEY.map((s, i) => (
        <li class={`jstep ${s.status}`}>
          <span class="jnum">{i + 1}</span>
          <span class="jlabel">{lang === 'pt' ? s.pt : s.en}</span>
        </li>
      ))}
    </ol>
  </div>
</section>

<!-- NOVIDADES -->
<section class="section" style="padding-top:0">
  <div class="container">
    <div style="display:flex; align-items:baseline; justify-content:space-between; gap:16px;">
      <h2>{tr('home.latest')}</h2>
      <a href={href('/devlog', lang)}>{tr('home.latest.all')}</a>
    </div>
    <div class="grid cols-3" style="margin-top:24px">
      {latest.map((e) => (
        <a class="card" href={href(`/devlog/${e.slug}`, lang)}>
          <span class="tag">{e.tag}</span>
          <h3>{e[lang].title}</h3>
          <div class="meta">#{e.session} · {e.date}</div>
          <p>{e[lang].summary}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- FRENTES -->
<section class="section" style="padding-top:0">
  <div class="container">
    <p class="eyebrow">{tr('home.what')}</p>
    <h2>{tr('home.pillars.title')}</h2>
    <p class="lead">{tr('home.what.body')}</p>
    <div class="grid cols-3">
      {pillars.map((p) => (
        <div class="card">
          <div style="font-size:1.8rem">{p.i}</div>
          <h3>{p.h}</h3>
          <p>{p.p}</p>
        </div>
      ))}
    </div>
  </div>
</section>
