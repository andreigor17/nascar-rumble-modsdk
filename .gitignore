# === NUNCA versionar a ISO original ou dumps de disco ===
*.bin
*.cue
*.iso
*.img
*.mdf
*.mds
NASCAR Rumble (USA)/

# Recursos extraídos (regeneráveis a partir da ISO)
extracted/
!extracted/.gitkeep

# Emulador: savestates, memory cards, BIOS
emulator/**
!emulator/.gitkeep
*.mcd
*.mcr
*.srm
*.sav
saves/*.mcd
saves/*.mcr
*.savestate
*.state
*.pxstate

# Ghidra: manter apenas exports .gzf/.xml, ignorar projeto de trabalho (qualquer nível)
*.rep/
*.gpr
*.lock
*.ghpr
# extensões do Ghidra (blob de 9MB, rebaixável via ROTEIRO_SETUP.md)
tools/ghidra_extensions/*.zip
ghidra/*.rep
# venv do PyGhidra e logs de execução
.venv-ghidra/
ghidra_out_run*.log
# saídas grandes do Ghidra (regeneráveis); versionamos só os CSVs de índice
ghidra_out/decomp_all.c
ghidra_out/func_*.c

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# Sistema
.DS_Store
Thumbs.db

# jpsxdec (baixado; ~MB)
tools/jpsxdec/

# logs de ferramentas
debug*.log

# snapshots de RAM do PCSX-Redux (regeneráveis)
experiments/ram/

# clone do RecompOne (build)
tools/RecompOne/

# RecompOne: código gerado e build do host
recompone/Recompiled/
recompone/host/bin/
recompone/host/obj/
