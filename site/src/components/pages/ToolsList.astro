---
import { SITE, type Lang } from '../../consts';
import { t } from '../../i18n/ui';
import { TOOLS } from '../../data/tools';
const { lang } = Astro.props as { lang: Lang };
const tr = t(lang);
---
<section class="section">
  <div class="container">
    <p class="eyebrow">SDK</p>
    <h2>{tr('tools.title')}</h2>
    <p class="lead">{tr('tools.intro')}</p>
    <div class="grid cols-2">
      {TOOLS.map((tool) => (
        <a class="card tool" href={`${SITE.github}/blob/main/${tool.file}`} target="_blank" rel="noopener">
          <code>{tool.file}</code>
          <p>{lang === 'pt' ? tool.pt : tool.en}</p>
        </a>
      ))}
    </div>
  </div>
</section>
